#include <stdio.h>
#include <stdlib.h>

int main() {
    int mode, hour, source, air, security, lights, alarm;
    char motion;
    float temp;
    int running = 1;

    while (running) {
        printf("\n--- OMNI-GUARD DASHBOARD ---\n");
        printf("0: Exit | 1: Disabled | 2: Home | 3: Away | 4: Panic\n");
        printf("Select Mode: ");
        
        if (scanf("%d", &mode) != 1) {
            printf("[!] Invalid input type. Please enter a number.\n");
            while(getchar() != '\n');
            continue;
        }

        if (mode == 0) {
            printf("System closing... See you developer!\n");
            running = 0;
            continue;
        }

        
        if (mode < 0 || mode > 4) {
            printf("\n[X] ERROR: Invalid mode! Redirecting to menu...\n");
            continue; 
        }

        
        security = 1; air = 0; alarm = 0; lights = 0; // lights=0 (Manual)

        
        printf("\n--- SENSOR SIMULATION ---\n");
        printf("Temperature: "); scanf("%f", &temp);
        
        if (temp < -20 || temp > 60) {
            printf("[X] Critical Sensor Range Error! Try again.\n");
            continue;
        }

        printf("Motion (Y/N): "); scanf(" %c", &motion);
        printf("Current Hour (0-23): "); scanf("%d", &hour);

        if (hour < 0 || hour > 23) {
            printf("[X] Time sync error! Enter a valid hour.\n");
            continue;
        }

        printf("Energy (1:Grid, 2:Battery, 3:Solar): "); scanf("%d", &source);

       
        if (mode == 4) { // Panic
            alarm = 2; lights = 2; air = 0;
        } else {
           
            switch (mode) {
                case 1: air = 2; security = 0; break;
                case 2:
                    if ((hour <= 6 || hour >= 22) || (motion == 'Y' || motion == 'y')) {
                        lights = 1; 
                    }
                    break;
                case 3:
                    if (motion == 'Y' || motion == 'y') alarm = 1;
                    air = 1;
                    break;
            }

            
            if ((source == 1 || source == 3) && (temp < 20 || temp > 25)) air = 2;
            else if (source == 2 && (temp < 15 || temp > 30)) air = 2;
        }

        printf("\n>> SYSTEM STATUS REPORT <<\n");
        printf("Mode    : %d\n", mode);
        printf("Alarm   : %s\n", (alarm == 2 ? "MAX ALERT" : (alarm == 1 ? "ACTIVE" : "Safe")));
        printf("Climate : %s\n", (air == 2 ? "Active" : (air == 1 ? "Eco-Mode" : "Off")));
        
        if (lights == 0) printf("Lights  : [MANUAL MODE]\n");
        else if (lights == 1) printf("Lights  : Hallway Active\n");
        else printf("Lights  : ALL OPEN (Emergency)\n");
        
        printf("---------------------------\n");
    }

    return 0;
}